{
  "manifest_version": 3,
  "name": "Daily Log",
  "version": "1.0.0",
  "description": "Track your daily goals with one-tap timers, a year-long heatmap, and per-goal targets. All data stays in your browser.",
  "author": "Yufan Chen",
  "action": {
    "default_title": "Open Daily Log",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
